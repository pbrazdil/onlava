{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.metrics.query.v1.schema.json",
  "title": "onlava.metrics.query.v1",
  "type": "object",
  "required": ["schema_version", "scope", "backend", "query", "result_type", "series"],
  "properties": {
    "schema_version": { "const": "onlava.metrics.query.v1" },
    "scope": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/scope" },
    "backend": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/backend" },
    "query": { "$ref": "#/$defs/query" },
    "result_type": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "series": { "type": "array", "items": { "$ref": "#/$defs/series" } }
  },
  "additionalProperties": false,
  "$defs": {
    "query": {
      "type": "object",
      "required": ["promql", "mode"],
      "properties": {
        "promql": { "type": "string" },
        "mode": { "enum": ["range", "instant"] },
        "since": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "step": { "type": "string" },
        "timeout": { "type": "string" },
        "limit": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "sample": {
      "type": "object",
      "required": ["time", "value"],
      "properties": {
        "time": { "type": "string" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "series": {
      "type": "object",
      "required": ["metric"],
      "properties": {
        "metric": { "type": "object", "additionalProperties": { "type": "string" } },
        "value": { "$ref": "#/$defs/sample" },
        "values": { "type": "array", "items": { "$ref": "#/$defs/sample" } }
      },
      "additionalProperties": false
    }
  }
}
