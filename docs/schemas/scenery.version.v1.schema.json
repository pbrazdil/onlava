{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.version.v1.schema.json",
  "title": "scenery version",
  "type": "object",
  "required": ["schema_version", "version", "go_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "scenery.version.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string"
    },
    "built_at": {
      "type": "string"
    },
    "go_version": {
      "type": "string",
      "minLength": 1
    },
    "module_version": {
      "type": "string"
    },
    "toolchain_manifest": {
      "type": "object",
      "required": ["schema_version", "sha256", "artifact_count", "source_lock_count"],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "scenery.toolchain.v1"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_lock_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
