{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.toolchain.status.v1.schema.json",
  "title": "onlava toolchain status",
  "type": "object",
  "required": ["schema_version", "manifest_sha256", "store_dir", "platform", "source_locks", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "onlava.toolchain.status.v1" },
    "manifest_sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "store_dir": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "source_locks": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_lock_status" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_status" }
    }
  },
  "$defs": {
    "source_lock_status": {
      "type": "object",
      "required": ["name", "kind", "manifest", "status"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "manager": { "type": "string" },
        "manifest": { "type": "string" },
        "lock": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "artifact_status": {
      "type": "object",
      "required": ["name", "kind", "version", "status"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "version": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "managed_path": { "type": "string" },
        "home_path": { "type": "string" },
        "message": { "type": "string" },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
