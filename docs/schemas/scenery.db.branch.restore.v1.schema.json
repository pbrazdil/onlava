{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.branch.restore.v1.schema.json",
  "title": "scenery DB Branch Restore Result v1",
  "type": "object",
  "required": ["schema_version", "branch", "branch_id", "restore_point", "status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "scenery.db.branch.restore.v1" },
    "branch": { "type": "string" },
    "branch_id": { "type": "string" },
    "restore_point": { "$ref": "#/$defs/restore_point" },
    "status": { "const": "restored" }
  },
  "$defs": {
    "restore_point": {
      "type": "object",
      "required": ["id", "created_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" },
        "lsn": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  }
}
