{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.db.neon.driver.capabilities.v1.schema.json",
  "title": "onlava Neon selfhost driver capabilities",
  "type": "object",
  "required": ["schema_version", "provider", "driver", "version", "status", "actions", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "onlava.db.neon.driver.capabilities.v1" },
    "provider": { "const": "neon-selfhost" },
    "driver": { "const": "neon-selfhost-driver" },
    "version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["partial", "ready", "degraded"] },
    "actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "message": { "type": "string" }
  }
}
