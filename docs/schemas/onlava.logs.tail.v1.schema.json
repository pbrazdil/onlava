{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.logs.tail.v1.schema.json",
  "title": "onlava.logs.tail.v1",
  "type": "object",
  "required": ["schema_version", "scope", "backend", "query", "logs"],
  "properties": {
    "schema_version": { "const": "onlava.logs.tail.v1" },
    "scope": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/scope" },
    "backend": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/backend" },
    "query": { "$ref": "onlava.logs.query.v1.schema.json#/$defs/query" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "logs": { "type": "array", "items": { "$ref": "onlava.logs.query.v1.schema.json#/$defs/log" } }
  },
  "additionalProperties": false
}
