{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.dev/schemas/pulse.wire.capabilities.v1.schema.json",
  "title": "pulse.wire.capabilities.v1",
  "type": "object",
  "required": ["schema_version", "wire_schema_hash", "content_type", "endpoints"],
  "properties": {
    "schema_version": { "const": "pulse.wire.capabilities.v1" },
    "wire_schema_hash": { "type": "string" },
    "content_type": { "const": "application/vnd.pulse.wire+bin" },
    "endpoints": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/endpoint" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "endpoint": {
      "type": "object",
      "required": ["id", "service", "endpoint", "path", "methods", "available", "safe_json_retry", "wire_path", "recovery_path_pattern"],
      "properties": {
        "id": { "type": "string" },
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "path": { "type": "string" },
        "methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "available": { "type": "boolean" },
        "unsupported_reason": { "type": "string" },
        "schema_hash": { "type": "string" },
        "safe_json_retry": { "type": "boolean" },
        "wire_path": { "type": "string" },
        "recovery_path_pattern": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
