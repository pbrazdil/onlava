{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.dev/schemas/pulse.run.event.v1.schema.json",
  "title": "pulse.run.event.v1",
  "description": "Reserved schema for future `pulse run --json` JSONL events.",
  "type": "object",
  "required": ["schema_version", "type", "time"],
  "properties": {
    "schema_version": { "const": "pulse.run.event.v1" },
    "type": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
