{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.setup.result.v1.schema.json",
  "title": "scenery.db.setup.result.v1",
  "type": "object",
  "required": ["schema_version", "app", "apply", "seed"],
  "properties": {
    "schema_version": { "const": "scenery.db.setup.result.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "apply": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "applied", "failed"]
        },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "seed": { "$ref": "#/$defs/seedResult" }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "seedResult": {
      "type": "object",
      "required": ["schema_version", "app", "dry_run", "seeds", "summary"],
      "properties": {
        "schema_version": { "const": "scenery.db.seed.result.v1" },
        "app": { "$ref": "#/$defs/appRef" },
        "dry_run": { "type": "boolean" },
        "seeds": {
          "type": "array",
          "items": { "$ref": "#/$defs/seed" }
        },
        "summary": {
          "type": "object",
          "required": ["planned", "applied", "skipped", "changed", "failed"],
          "properties": {
            "planned": { "type": "integer", "minimum": 0 },
            "applied": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "changed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "seed": {
      "type": "object",
      "required": ["service", "path", "sha256", "status"],
      "properties": {
        "service": { "type": "string" },
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["planned", "applied", "skipped", "changed", "failed"]
        },
        "error": { "type": "string" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/seedDiagnostic" }
        }
      },
      "additionalProperties": false
    },
    "seedDiagnostic": {
      "type": "object",
      "required": ["path", "line", "message", "context"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "message": { "type": "string" },
        "context": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
