{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.db.neon.selfhost.backend.v1.schema.json",
  "title": "onlava Neon selfhost backend state",
  "type": "object",
  "required": ["schema_version", "provider", "tenant_id", "default_pg_version", "branches"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "onlava.db.neon.selfhost.backend.v1" },
    "provider": { "const": "neon-selfhost" },
    "tenant_id": { "type": "string" },
    "default_pg_version": { "type": "integer", "minimum": 1 },
    "branches": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/branch" }
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "branch": {
      "type": "object",
      "required": ["project", "branch", "timeline_id", "endpoint_id", "compute_container", "host", "port", "database", "role", "status"],
      "additionalProperties": false,
      "properties": {
        "project": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "timeline_id": { "type": "string", "minLength": 1 },
        "parent_timeline_id": { "type": "string" },
        "endpoint_id": { "type": "string", "minLength": 1 },
        "compute_container": { "type": "string", "minLength": 1 },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pending", "starting", "ready", "degraded", "deleted", "tombstoned"] },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
