{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.metrics.series.v1.schema.json",
  "title": "scenery.metrics.series.v1",
  "type": "object",
  "required": ["schema_version", "scope", "backend", "query", "series"],
  "properties": {
    "schema_version": { "const": "scenery.metrics.series.v1" },
    "scope": { "$ref": "scenery.inspect.observability.v1.schema.json#/$defs/scope" },
    "backend": { "$ref": "scenery.inspect.observability.v1.schema.json#/$defs/backend" },
    "query": { "$ref": "scenery.metrics.labels.v1.schema.json#/$defs/query" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "series": { "type": "array", "items": { "type": "object", "additionalProperties": { "type": "string" } } }
  },
  "additionalProperties": false
}
