{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.logs.query.v1.schema.json",
  "title": "onlava.logs.query.v1",
  "type": "object",
  "required": ["schema_version", "scope", "backend", "query", "logs"],
  "properties": {
    "schema_version": { "const": "onlava.logs.query.v1" },
    "scope": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/scope" },
    "backend": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/backend" },
    "query": { "$ref": "#/$defs/query" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "logs": { "type": "array", "items": { "$ref": "#/$defs/log" } }
  },
  "additionalProperties": false,
  "$defs": {
    "query": {
      "type": "object",
      "required": ["query", "start", "end"],
      "properties": {
        "query": { "type": "string" },
        "since": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "limit": { "type": "integer" },
        "timeout": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "log": {
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "level": { "type": "string" },
        "source": { "type": "string" },
        "message": { "type": "string" },
        "fields": { "type": "object" },
        "trace_id": { "type": "string" },
        "span_id": { "type": "string" },
        "raw": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
