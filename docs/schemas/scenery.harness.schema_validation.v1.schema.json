{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.harness.schema_validation.v1.schema.json",
  "title": "scenery harness schema validation report",
  "type": "object",
  "required": ["schema_version", "validated"],
  "properties": {
    "schema_version": {
      "const": "scenery.harness.schema_validation.v1"
    },
    "validated": {
      "type": "array",
      "items": { "$ref": "#/$defs/validated_item" }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "validated_item": {
      "type": "object",
      "required": ["name", "schema", "ok"],
      "properties": {
        "name": { "type": "string" },
        "schema": { "type": "string" },
        "ok": { "type": "boolean" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
