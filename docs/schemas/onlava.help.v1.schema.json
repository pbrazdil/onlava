{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.help.v1.schema.json",
  "title": "onlava.help.v1",
  "type": "object",
  "required": ["schema_version", "commands"],
  "properties": {
    "schema_version": { "const": "onlava.help.v1" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "group", "summary", "usage", "json", "stability"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "group": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "usage": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "subcommands": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "flags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "json": { "type": "boolean" },
          "stability": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
