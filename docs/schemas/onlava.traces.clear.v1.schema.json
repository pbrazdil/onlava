{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.traces.clear.v1.schema.json",
  "title": "onlava.traces.clear.v1",
  "type": "object",
  "required": ["schema_version", "ok", "command", "app"],
  "properties": {
    "schema_version": { "const": "onlava.traces.clear.v1" },
    "ok": { "type": "boolean" },
    "command": { "const": "onlava traces clear" },
    "app": { "$ref": "#/$defs/appRef" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data": {
      "type": "object",
      "properties": {
        "app_id": { "type": "string" },
        "cleared": { "const": "traces" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
