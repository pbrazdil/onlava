{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.check.result.v1.schema.json",
  "title": "scenery.check.result.v1",
  "description": "Schema for `scenery check --json` responses.",
  "type": "object",
  "required": ["schema_version", "ok", "app", "diagnostics"],
  "properties": {
    "schema_version": { "const": "scenery.check.result.v1" },
    "ok": { "type": "boolean" },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "severity", "message"],
        "properties": {
          "stage": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "column": { "type": "integer", "minimum": 1 },
          "message": { "type": "string" },
          "suggested_action": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
