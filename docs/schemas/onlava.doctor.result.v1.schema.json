{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.doctor.result.v1.schema.json",
  "title": "onlava doctor result",
  "type": "object",
  "required": ["schema_version", "ok", "summary", "onlava", "environment", "checks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "onlava.doctor.result.v1" },
    "ok": { "type": "boolean" },
    "summary": { "$ref": "#/$defs/summary" },
    "onlava": { "$ref": "onlava.version.v1.schema.json" },
    "app": { "$ref": "#/$defs/app" },
    "environment": { "$ref": "#/$defs/environment" },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "required": ["ok", "warnings", "errors", "skipped"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "app": {
      "type": "object",
      "required": ["root", "config_path", "name"],
      "additionalProperties": false,
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "config_path": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "required": ["goos", "goarch", "num_cpu", "paths"],
      "additionalProperties": false,
      "properties": {
        "goos": { "type": "string", "minLength": 1 },
        "goarch": { "type": "string", "minLength": 1 },
        "num_cpu": { "type": "integer", "minimum": 0 },
        "total_memory_bytes": { "type": "integer", "minimum": 0 },
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_report" }
        }
      }
    },
    "path_report": {
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "free_bytes": { "type": "integer", "minimum": 0 },
        "total_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "check": {
      "type": "object",
      "required": ["id", "category", "name", "status", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["ok", "warn", "error", "skipped"] },
        "severity": { "enum": ["required", "optional", "informational"] },
        "message": { "type": "string", "minLength": 1 },
        "suggested_action": { "type": "string" },
        "observed": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
