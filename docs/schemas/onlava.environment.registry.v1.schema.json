{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.environment.registry.v1.schema.json",
  "title": "onlava environment registry",
  "type": "object",
  "required": ["schema_version", "variables"],
  "properties": {
    "schema_version": { "const": "onlava.environment.registry.v1" },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/$defs/variable" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "variable": {
      "type": "object",
      "required": [
        "name",
        "scope",
        "direction",
        "category",
        "stability",
        "secret",
        "allowed_in",
        "owner",
        "rationale",
        "preferred_surface",
        "docs"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "match": { "enum": ["exact", "prefix", "glob"] },
        "scope": { "enum": ["runtime", "internal", "test_only"] },
        "direction": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "stability": { "type": "string", "minLength": 1 },
        "secret": { "type": "boolean" },
        "allowed_in": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["code", "docs", "tests"] }
        },
        "owner": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "preferred_surface": { "type": "string", "minLength": 1 },
        "replacement": { "type": "string" },
        "sunset": { "type": "string" },
        "docs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
