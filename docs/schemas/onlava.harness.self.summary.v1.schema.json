{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.harness.self.summary.v1.schema.json",
  "title": "onlava self harness summary",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "status",
    "generated_at",
    "mode",
    "repo",
    "can_proceed",
    "changed_area",
    "diagnostic_summary",
    "steps",
    "reports",
    "artifacts",
    "drilldowns"
  ],
  "properties": {
    "schema_version": { "const": "onlava.harness.self.summary.v1" },
    "ok": { "type": "boolean" },
    "status": { "enum": ["pass", "pass_with_warnings", "pass_with_debt", "fail", "skipped"] },
    "generated_at": { "type": "string" },
    "mode": { "enum": ["default", "quick", "race", "release"] },
    "repo": {
      "type": "object",
      "required": ["root", "module_path", "go_mod_path"],
      "properties": {
        "root": { "type": "string" },
        "module_path": { "const": "github.com/pbrazdil/onlava" },
        "go_mod_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "can_proceed": { "type": "boolean" },
    "changed_area": { "type": "object", "additionalProperties": true },
    "diagnostic_summary": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "attention": {
      "type": "array",
      "maxItems": 10,
      "items": { "$ref": "#/$defs/attention" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "reports": { "type": "object", "additionalProperties": true },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "drilldowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wrote": { "type": "string" }
  },
  "additionalProperties": false,
  "$defs": {
    "attention": {
      "type": "object",
      "required": ["severity", "category", "message"],
      "properties": {
        "severity": { "type": "string" },
        "category": { "type": "string" },
        "message": { "type": "string" },
        "next_action": { "type": "string" },
        "top_entries": { "type": "array", "items": { "type": "string" } },
        "omitted_count": { "type": "integer" },
        "artifact": { "type": "string" },
        "drilldown": { "type": "string" }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["id", "name", "status", "duration_ms", "error_count", "warning_count"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "enum": ["pass", "warning", "fail", "skipped"] },
        "duration_ms": { "type": "integer" },
        "error_count": { "type": "integer" },
        "warning_count": { "type": "integer" },
        "summary": { "type": "object", "additionalProperties": true },
        "diagnostics": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "output_tail": { "type": "string", "maxLength": 2000 },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["name", "path", "exists"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "schema_version": { "type": "string" },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
