{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.harness.drift.v1.schema.json",
  "title": "scenery harness drift report",
  "type": "object",
  "required": ["schema_version", "cli", "env", "artifacts", "embeds"],
  "properties": {
    "schema_version": { "const": "scenery.harness.drift.v1" },
    "cli": { "type": "object", "additionalProperties": true },
    "env": {
      "type": "object",
      "required": ["variables"],
      "properties": {
        "registry": { "type": "string" },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/env_variable" }
        }
      },
      "additionalProperties": false
    },
    "artifacts": { "type": "object", "additionalProperties": true },
    "embeds": { "type": "object", "additionalProperties": true },
    "diagnostics": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "env_variable": {
      "type": "object",
      "required": ["name", "scope", "used_in_code", "documented", "registered"],
      "properties": {
        "name": { "type": "string" },
        "scope": { "type": "string" },
        "used_in_code": { "type": "boolean" },
        "documented": { "type": "boolean" },
        "registered": { "type": "boolean" },
        "registry_name": { "type": "string" },
        "direction": { "type": "string" },
        "stability": { "type": "string" },
        "category": { "type": "string" },
        "secret": { "type": "boolean" },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "kind", "scope"],
            "properties": {
              "file": { "type": "string" },
              "kind": { "type": "string" },
              "scope": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "violations": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
